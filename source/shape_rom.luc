                            c{1b1, 4h1, 1b0, 4h2},
                            c{1b1, 4h2, 1b0, 4h2},
                                
                            c{1b0, 4h0, 1b0, 4h3},
                            c{1b0, 4h1, 1b0, 4h3},
                            c{1b1, 4h1, 1b0, 4h3},
                            10b0, 10b0, 10b0, 10b0, 10b0, 10b0, 10b0, 10b0, 10b0, 10b0,
                            10b0, 10b0, 10b0, 10b0, 10b0, 10b0, 10b0, 10b0, 10b0, 10b0,
                            10b0, 10b0, 10b0, 10b0, 10b0, 10b0, 10b0, 10b0, 10b0, 10b0,
                            10b0, 10b0, 10b0
                        })
                    Globals.RIGHT:
                        data = $reverse({
                            c{1b0, 4h0, 1b1, 4h1},
                            c{1b0, 4h1, 1b1, 4h1},
                            c{1b0, 4h2, 1b1, 4h1},
                            c{1b1, 4h1, 1b1, 4h1},
                            c{1b1, 4h2, 1b1, 4h1},
                                
                            c{1b0, 4h0, 1b1, 4h2},
                            c{1b0, 4h1, 1b1, 4h2},
                            c{1b0, 4h2, 1b1, 4h2},
                            c{1b1, 4h1, 1b1, 4h2},
                            c{1b1, 4h2, 1b1, 4h2},
                                
                            c{1b0, 4h0, 1b1, 4h3},
                            c{1b0, 4h1, 1b1, 4h3},
                            c{1b1, 4h1, 1b1, 4h3},
                            10b0, 10b0, 10b0, 10b0, 10b0, 10b0, 10b0, 10b0, 10b0, 10b0,
                            10b0, 10b0, 10b0, 10b0, 10b0, 10b0, 10b0, 10b0, 10b0, 10b0,
                            10b0, 10b0, 10b0, 10b0, 10b0, 10b0, 10b0, 10b0, 10b0, 10b0,
                            10b0, 10b0, 10b0
                        })
                }
        }
        shape_offset = data[addr[$clog2(SLOTS_PER_SHAPE)-1:0]]
    }
}