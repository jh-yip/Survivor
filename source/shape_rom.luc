                            c{1b0, 4hE, 1b1, 4h7},
                            c{1b0, 4hF, 1b1, 4h8},
                            10b0
                        })
                    Globals.LEFT:
                        data = $reverse({
                            c{1b0, 4h0, 1b0, 4h1},
                            c{1b0, 4h0, 1b0, 4h2},
                            c{1b0, 4h0, 1b0, 4h3},
                            c{1b0, 4h0, 1b0, 4h4},
