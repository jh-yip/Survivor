                            c{1b1, 4hC, 1b1, 4h6},
                            c{1b1, 4hD, 1b1, 4h7},
                            c{1b1, 4hE, 1b1, 4h7},
                            c{1b1, 4hF, 1b1, 4h8},
                            10b0
                        })
