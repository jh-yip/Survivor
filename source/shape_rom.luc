                            c{1b1, 4h7, 1b1, 4hE},
                            c{1b1, 4h8, 1b1, 4hF},
                            10b0
                        })
                }
            Globals.BLAST:
                case (direction) {
                    Globals.UP:
                        data = $reverse({
                            c{1b1, 4h1, 1b0, 4h0},
                            c{1b1, 4h1, 1b0, 4h1},
                            c{1b1, 4h1, 1b1, 4h1},
                                
