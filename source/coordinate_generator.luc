            32: random_ammo_coords = 8h4A
            33: random_ammo_coords = 8h4B
            34: random_ammo_coords = 8h4C
            35: random_ammo_coords = 8h4D
            
            // Row 5
            36: random_ammo_coords = 8h52
            37: random_ammo_coords = 8h53
            38: random_ammo_coords = 8h54
            39: random_ammo_coords = 8h55
            40: random_ammo_coords = 8h56
            41: random_ammo_coords = 8h57
            42: random_ammo_coords = 8h58
            43: random_ammo_coords = 8h59
            44: random_ammo_coords = 8h5A
            45: random_ammo_coords = 8h5B
            46: random_ammo_coords = 8h5C
            47: random_ammo_coords = 8h5D
            
            // Row 6
            48: random_ammo_coords = 8h62
            49: random_ammo_coords = 8h63
            50: random_ammo_coords = 8h64
            51: random_ammo_coords = 8h65
            52: random_ammo_coords = 8h66
            53: random_ammo_coords = 8h67
            54: random_ammo_coords = 8h68
            55: random_ammo_coords = 8h69
            56: random_ammo_coords = 8h6A
            57: random_ammo_coords = 8h6B
            58: random_ammo_coords = 8h6C
            59: random_ammo_coords = 8h6D
            
            // Row 7
            60: random_ammo_coords = 8h72
            61: random_ammo_coords = 8h73
            62: random_ammo_coords = 8h74
            63: random_ammo_coords = 8h75
            64: random_ammo_coords = 8h76
            65: random_ammo_coords = 8h77
            66: random_ammo_coords = 8h78
            67: random_ammo_coords = 8h79
