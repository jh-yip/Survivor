            80: random_ammo_coords = 8h8A
            81: random_ammo_coords = 8h8B
            82: random_ammo_coords = 8h8C
            83: random_ammo_coords = 8h8D
            
            // Row 9
            84: random_ammo_coords = 8h92
            85: random_ammo_coords = 8h93
            86: random_ammo_coords = 8h94
            87: random_ammo_coords = 8h95
            88: random_ammo_coords = 8h96
            89: random_ammo_coords = 8h97
