/******************************************************************************

   coordinate_generator: This module outputs two "random" coordinates.
   edge coordinates are any coordinate along the 1-square wide edge for enemy spawns.
   ammo coordinates are any coordinate in the inner 12x12 square (excludes the 2-square wide border).
   
   This module does not use a pseudorandom algorithm.
   it simply relies on a counter that reads from a scrambled ROM.
   
******************************************************************************/
module coordinate_generator (
    input clk,  // clock
    output random_edge_coords[8],
    output random_ammo_coords[8]
) {
    counter random_edge_coords_counter(.clk(clk), .rst(1b0), #SIZE($clog2(61)), #TOP(60)) // there are 60 possible edge coords, 1 extra to prevent deadlock
    counter random_ammo_coords_counter(.clk(clk), .rst(1b0), #SIZE($clog2(144)), #TOP(143)) // there are 144 possible ammo coords
    
    sig random_edge_coords_index[6] = random_edge_coords_counter.value
    sig random_ammo_coords_index[8] = random_ammo_coords_counter.value
    
    always {
        // random_edge_coords (random order)
        case (random_edge_coords_index) {
            0:  random_edge_coords = 8hF3
            1:  random_edge_coords = 8h07
            2:  random_edge_coords = 8hA0
            3:  random_edge_coords = 8h3F
            4:  random_edge_coords = 8h02
            5:  random_edge_coords = 8hFC
            6:  random_edge_coords = 8h60
            7:  random_edge_coords = 8h1F
            8:  random_edge_coords = 8hF0
            9:  random_edge_coords = 8h0A
            10: random_edge_coords = 8h8F
            11: random_edge_coords = 8h20
            12: random_edge_coords = 8h0D
            13: random_edge_coords = 8hC0
            14: random_edge_coords = 8hF8
            15: random_edge_coords = 8h40
            16: random_edge_coords = 8h01
            17: random_edge_coords = 8hFE
            18: random_edge_coords = 8h90
            19: random_edge_coords = 8h7F
            20: random_edge_coords = 8hF5
            21: random_edge_coords = 8h0B
            22: random_edge_coords = 8hDF
            23: random_edge_coords = 8h5F
            24: random_edge_coords = 8h06
            25: random_edge_coords = 8hF2
            26: random_edge_coords = 8h30
            27: random_edge_coords = 8hE0
            28: random_edge_coords = 8h04
            29: random_edge_coords = 8hBF
            30: random_edge_coords = 8h10
            31: random_edge_coords = 8hF9
            32: random_edge_coords = 8h6F
            33: random_edge_coords = 8h0E
            34: random_edge_coords = 8h9F
            35: random_edge_coords = 8hF6
            36: random_edge_coords = 8h2F
            37: random_edge_coords = 8hCF
            38: random_edge_coords = 8h09
            39: random_edge_coords = 8hAF
            40: random_edge_coords = 8h4F
            41: random_edge_coords = 8hF1
            42: random_edge_coords = 8hEF
            43: random_edge_coords = 8h03
            44: random_edge_coords = 8h50
            45: random_edge_coords = 8hFB
            46: random_edge_coords = 8h80
            47: random_edge_coords = 8h08
            48: random_edge_coords = 8h70
            49: random_edge_coords = 8hD0
            50: random_edge_coords = 8h05
            51: random_edge_coords = 8hF4
            52: random_edge_coords = 8hB0
            53: random_edge_coords = 8h0C
            54: random_edge_coords = 8hF7
            55: random_edge_coords = 8h3F
            56: random_edge_coords = 8h1F
            57: random_edge_coords = 8h20
            58: random_edge_coords = 8hFA
            59: random_edge_coords = 8hFF
            60: random_edge_coords = 8h00 // extra
            default: random_edge_coords = 8hx
        }       
        
        // random_ammo_coords
        case (random_ammo_coords_index) {
            // Row 2
            0: random_ammo_coords = 8h22
            1: random_ammo_coords = 8h23
            2: random_ammo_coords = 8h24
            3: random_ammo_coords = 8h25
            4: random_ammo_coords = 8h26
            5: random_ammo_coords = 8h27
            6: random_ammo_coords = 8h28
            7: random_ammo_coords = 8h29
            8: random_ammo_coords = 8h2A
            9: random_ammo_coords = 8h2B
            10: random_ammo_coords = 8h2C
            11: random_ammo_coords = 8h2D
            
            // Row 3
            12: random_ammo_coords = 8h32
            13: random_ammo_coords = 8h33
            14: random_ammo_coords = 8h34
            15: random_ammo_coords = 8h35
            16: random_ammo_coords = 8h36
            17: random_ammo_coords = 8h37
            18: random_ammo_coords = 8h38
            19: random_ammo_coords = 8h39
            20: random_ammo_coords = 8h3A
            21: random_ammo_coords = 8h3B
            22: random_ammo_coords = 8h3C
            23: random_ammo_coords = 8h3D
            
            // Row 4
            24: random_ammo_coords = 8h42
            25: random_ammo_coords = 8h43
            26: random_ammo_coords = 8h44
            27: random_ammo_coords = 8h45
            28: random_ammo_coords = 8h46
            29: random_ammo_coords = 8h47
            30: random_ammo_coords = 8h48
