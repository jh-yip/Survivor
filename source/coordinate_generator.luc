            95: random_ammo_coords = 8h9D
            
            // Row 10
            96: random_ammo_coords = 8hA2
            97: random_ammo_coords = 8hA3
            98: random_ammo_coords = 8hA4
            99: random_ammo_coords = 8hA5
            100: random_ammo_coords = 8hA6
            101: random_ammo_coords = 8hA7
            102: random_ammo_coords = 8hA8
            103: random_ammo_coords = 8hA9
            104: random_ammo_coords = 8hAA
            105: random_ammo_coords = 8hAB
            106: random_ammo_coords = 8hAC
            107: random_ammo_coords = 8hAD
            
            // Row 11
            108: random_ammo_coords = 8hB2
            109: random_ammo_coords = 8hB3
            110: random_ammo_coords = 8hB4
            111: random_ammo_coords = 8hB5
