testbench test_alu {
    const TEST_VALUES_ALU = $reverse({
        //a              b              alunfn  expected       z   v   n 
        c{32d0,          32d0,          6h00, c{32d0,          1b1,1b0,1b0}}, // 00 ADD 0+0
        c{32h7FFFFFFF,   32d1,          6h00, c{32h80000000,   1b0,1b1,1b1}}, // 01 ADD pos overflow
        
        c{32d7,          32d5,          6h01, c{32d2,          1b0,1b0,1b0}}, // 02 SUB 7-5
        c{32h80000000,   32d1,          6h01, c{32h7FFFFFFF,   1b0,1b1,1b0}}, // 03 SUB neg overflow
        
        c{32d6,          32d7,          6h02, c{32d42,         1bx,1bx,1bx}}, // 04 MUL 3*4
        c{32h80000000,   32d2,          6h02, c{32d0,          1bx,1bx,1bx}}, // 05 MUL 80000000*2 (overflow)
        
        c{32hF0F0F0F0,   32h0F0F0F0F,   6h18, c{32h00000000,   1bx,1bx,1bx}}, // 06 AND mask clears to zero
        c{32hF0F0F0F0,   32h0F0F0F0F,   6h1E, c{32hFFFFFFFF,   1bx,1bx,1bx}}, // 07 OR fills all bits
        c{32hAAAA5555,   32hFFFF0000,   6h16, c{32h55555555,   1bx,1bx,1bx}}, // 08 XOR pattern
        
        c{32d5,          32d7,          6h1A, c{32d5,          1bx,1bx,1bx}}, // 09 "A" 5,7
        
        c{32d1,          32d3,          6h20, c{32d8,          1bx,1bx,1bx}}, // 10 SHL 1<<3
        c{32d16,         32d1,          6h21, c{32d8,          1bx,1bx,1bx}}, // 11 SHR 16>>1
        c{32h80000000,   32d1,          6h23, c{32hC0000000,   1bx,1bx,1bx}}, // 12 SRA 80000000>>1
        
        c{32d5,          32d5,          6h33, c{32d1,          1bx,1bx,1bx}}, // 13 CMPEQ 5==5
        c{32d3,          32d7,          6h35, c{32d1,          1bx,1bx,1bx}}, // 14 CMPLT 3<7 true
        c{32d5,          32d5,          6h37, c{32d1,          1bx,1bx,1bx}}, // 15 CMPLE 5<=5

        c{32h00,         32h00,         6h39, c{32h00,         1bx,1bx,1bx}}, // 16 APPR (0,0) and (0,0) outputs (0,0)
        c{32h00,         32h11,         6h39, c{32h11,         1bx,1bx,1bx}}, // 17 APPR (0,0) and (1,1) outputs (1,1)
        c{32h00,         32h33,         6h39, c{32h11,         1bx,1bx,1bx}}, // 18 APPR (0,0) and (3,3) outputs (1,1)
        c{32h35,         32h73,         6h39, c{32h44,         1bx,1bx,1bx}}, // 19 APPR (3,5) and (7,3) outputs (4,4)
        c{32h65,         32h33,         6h39, c{32h54,         1bx,1bx,1bx}}, // 20 APPR (6,5) and (3,3) outputs (5,4)
        c{32h55,         32h38,         6h39, c{32h46,         1bx,1bx,1bx}}, // 21 APPR (5,5) and (3,8) outputs (4,6)

        c{32h00,         32b00000_00000, 6h38, c{32h00,         1bx,1bx,1bx}}, // 22 MOVE (0,0) and 0000 outputs (0, 0)
        c{32h55,         32b00001_00000, 6h38, c{32h65,         1bx,1bx,1bx}}, // 23 MOVE (5,5) and ( 0,+1) outputs (5, 6) (move down)
        c{32h55,         32b10001_00000, 6h38, c{32h45,         1bx,1bx,1bx}}, // 24 MOVE (5,5) and (-1, 0) outputs (4, 5) (move up)
        c{32h55,         32b00000_00001, 6h38, c{32h56,         1bx,1bx,1bx}}, // 25 MOVE (5,5) and ( 0,+1) outputs (5, 6) (move right)
        c{32h55,         32b00000_10001, 6h38, c{32h54,         1bx,1bx,1bx}}, // 26 MOVE (5,5) and ( 0,-1) outputs (5, 4) (move left)
        c{32h00,         32b00000_10001, 6h38, c{32h3FF,        1bx,1bx,1bx}}, // 27 MOVE (0,0) and ( 0,-1) outputs -1 (negative out of bounds)
        c{32h00,         32b10001_00000, 6h38, c{32h3FF,        1bx,1bx,1bx}}, // 28 MOVE (0,0) and (-1, 0) outputs -1 (negative out of bounds)
        c{32hF0,         32b00001_00000, 6h38, c{32h3FF,        1bx,1bx,1bx}}, // 29 MOVE (16,0) and (+1, 0) outputs -1 (positive out of bounds)
        c{32h0F,         32b00000_00001, 6h38, c{32h3FF,        1bx,1bx,1bx}}, // 30 MOVE (0,16) and ( 0,+1) outputs -1 (positive out of bounds)
    
        c{32h55,         32b00011_00100, 6h38, c{32h89,         1bx,1bx,1bx}}, // 31 MOVE (5,5) and (+3,+4) outputs (8, 9)
        c{32h55,         32b10010_10101, 6h38, c{32h30,         1bx,1bx,1bx}}, // 32 MOVE (5,5) and (-2,-5) outputs (3, 0)
        c{32h55,         32b10101_01010, 6h38, c{32h0F,         1bx,1bx,1bx}}, // 33 MOVE (5,5) and (-5,+10) outputs (0,15)
        c{32h55,         32b10110_01010, 6h38, c{32h3FF,        1bx,1bx,1bx}}, // 34 MOVE (5,5) and (-6,+10) outputs -1 (OOB)
        c{32h55,         32b10101_01011, 6h38, c{32h3FF,        1bx,1bx,1bx}}, // 35 MOVE (5,5) and (-5,+11) outputs -1 (OOB)
            
        c{32b00000_00001,   32hDEADBEEF, 6h3A, c{32b00000_10001,1bx,1bx,1bx}}, // 36 REV (0,+1) outputs (0,-1)
        c{32b00000_10001,   32hDEADBEEF, 6h3A, c{32b00000_00001,1bx,1bx,1bx}}, // 37 REV (0,-1) outputs (0,+1)
        c{32b00001_00000,   32hDEADBEEF, 6h3A, c{32b10001_00000,1bx,1bx,1bx}}, // 38 REV (+1,0) outputs (-1,0)
        c{32b10001_00000,   32hDEADBEEF, 6h3A, c{32b00001_00000,1bx,1bx,1bx}}  // 39 REV (-1,0) outputs (+1,0)
    })
    
    sig expected_out[32]
    sig expected_z
    sig expected_v
    sig expected_n

    alu alu
    test aluTest {
         repeat(i, 40){ 
            alu.a = TEST_VALUES_ALU[i][104:73]
            alu.b = TEST_VALUES_ALU[i][72:41]
            alu.alufn = TEST_VALUES_ALU[i][40:35]
            
            expected_out = TEST_VALUES_ALU[i][34:3]
            expected_z = TEST_VALUES_ALU[i][2]
            expected_v = TEST_VALUES_ALU[i][1]
            expected_n = TEST_VALUES_ALU[i][0]
            
            $silent_tick()
            
            $print("### TEST CASE %d ###", i)
            $print("ALU output: 32h%h, 1b%b, 1b%b, 1b%b" , alu.out, alu.z, alu.v, alu.n)
            $print("Expected: 32h%h, 1b%b, 1b%b, 1b%b" , expected_out, expected_z, expected_v, expected_n)
            $assert (alu.out == expected_out)
            $print("Result: PASS")
            $print(" ")
        }
    }
}